#!/bin/sh
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
else
    printf '%s\n' '{"error":"Python was not found","error_type":"runtime","hint":"Install Python 3.10 or use the Python bundled with your agent runtime."}' >&2
    exit 1
fi

exec "$PYTHON_BIN" "$SCRIPT_DIR/scripts/run_pipeline.py" "$@"
